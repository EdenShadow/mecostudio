#!/usr/bin/env bash
# Feishu Upload Script
# Usage: feishu-upload <file_path>

if [ -z "$1" ]; then
    echo "Usage: feishu-upload <file_path>"
    exit 1
fi

FILE_PATH="$1"
FILE_NAME=$(basename "$FILE_PATH")

# 获取token
TOKEN=$(curl -s -X POST "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token" \
    -H "Content-Type: application/json" \
    -d "{\"app_id\":\"cli_a900506216cb2\",\"app_secret\":\"Ma7i5O239TuL8MO843wnmdp6YQtR6WJ"}" \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('tenant_access_token')" 2>/dev/null)

# 上传文件
echo "Uploading $FILE_NAME..."
curl -s -X POST "https://open.feishu.cn/open-apis/im/v1/files" \
    -H "Authorization: Bearer $TOKEN" \
    -F "file_type=mp4" \
    -F "file_name=$FILE_NAME" \
    -F "file=@$FILE_PATH"

echo ""
echo "✅ 上传完成"
