#!/usr/bin/env python3
"""
Secret Notes CLI - 异步记笔记
文件名: {agent_name}_{YYYYMMDD}_{HHMMSS}.json
"""

import subprocess
import sys
import os

SKILL_DIR = os.path.dirname(os.path.realpath(__file__))
NOTE_SCRIPT = os.path.join(SKILL_DIR, "note.py")

def main():
    """
    异步写入笔记
    usage: secret-notes <agent_name> <task_description>
    
    Example: secret-notes main "记得查量子计算资料"
    """
    if len(sys.argv) < 3:
        print("Usage: secret-notes <agent_name> <task_description>")
        print("Example: secret-notes main '灵光一现的想法'")
        sys.exit(1)
    
    agent_name = sys.argv[1]
    task = ' '.join(sys.argv[2:])
    
    # 使用 nohup 异步执行，不等待结果
    cmd = ['nohup', 'python3', NOTE_SCRIPT, agent_name, task]
    
    try:
        # 异步启动，立即返回
        subprocess.Popen(
            cmd,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True
        )
        # 立即退出，不等待
        sys.exit(0)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
