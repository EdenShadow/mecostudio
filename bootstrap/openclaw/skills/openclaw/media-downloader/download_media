#!/usr/bin/env python3
"""
Media Downloader - 使用哼哼猫 API 下载视频/图片
"""

import argparse
import json
import os
import sys
import urllib.request
import urllib.parse
import ssl

# 哼哼猫 API 配置（从环境变量读取）
API_KEY = (
    os.environ.get("MEOWLOAD_API_KEY", "").strip()
    or os.environ.get("HENGHENGMAO_API_KEY", "").strip()
)
BASE_URL = os.environ.get("MEOWLOAD_BASE_URL", "https://api.meowload.com").strip()

def download_media(url, media_type="auto", output_dir=None):
    """
    使用哼哼猫 API 下载媒体文件
    
    Args:
        url: 媒体链接
        media_type: 类型 (video/image/auto)
        output_dir: 输出目录
    """
    if output_dir is None:
        output_dir = os.getcwd()
    
    # 确保输出目录存在
    os.makedirs(output_dir, exist_ok=True)
    
    if not API_KEY:
        print("❌ 缺少 MeowLoad API Key，请配置 MEOWLOAD_API_KEY")
        return None

    # 构建 API 请求
    api_endpoint = f"{BASE_URL}/v1/download"
    
    headers = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json",
        "User-Agent": "OpenClaw-MediaDownloader/1.0"
    }
    
    data = {
        "url": url,
        "type": media_type if media_type != "auto" else None
    }
    
    try:
        # 创建 SSL 上下文（允许访问 HTTPS）
        ctx = ssl.create_default_context()
        
        # 发送请求
        req = urllib.request.Request(
            api_endpoint,
            data=json.dumps(data).encode('utf-8'),
            headers=headers,
            method='POST'
        )
        
        print(f"正在解析链接: {url}")
        
        with urllib.request.urlopen(req, context=ctx, timeout=60) as response:
            result = json.loads(response.read().decode('utf-8'))
            
            if result.get('success') or result.get('code') == 200:
                download_url = result.get('data', {}).get('downloadUrl') or result.get('url')
                filename = result.get('data', {}).get('filename') or result.get('filename')
                
                if not filename:
                    # 从 URL 生成文件名
                    parsed = urllib.parse.urlparse(url)
                    filename = os.path.basename(parsed.path) or "media"
                    if not filename.endswith(('.mp4', '.jpg', '.jpeg', '.png', '.gif', '.webp')):
                        filename += ".mp4" if media_type == "video" else ".jpg"
                
                output_path = os.path.join(output_dir, filename)
                
                # 下载文件
                print(f"正在下载: {filename}")
                urllib.request.urlretrieve(download_url, output_path)
                
                print(f"✅ 下载完成: {output_path}")
                return output_path
            else:
                print(f"❌ API 错误: {result.get('message', '未知错误')}")
                return None
                
    except urllib.error.HTTPError as e:
        print(f"❌ HTTP 错误: {e.code} - {e.reason}")
        try:
            error_body = e.read().decode('utf-8')
            print(f"错误详情: {error_body}")
        except:
            pass
        return None
    except Exception as e:
        print(f"❌ 错误: {str(e)}")
        return None

def main():
    parser = argparse.ArgumentParser(description='下载媒体文件')
    parser.add_argument('url', help='媒体链接')
    parser.add_argument('--type', choices=['video', 'image', 'auto'], 
                        default='auto', help='媒体类型')
    parser.add_argument('--output', '-o', default=None, 
                        help='输出目录 (默认: 当前目录)')
    
    args = parser.parse_args()
    
    result = download_media(args.url, args.type, args.output)
    sys.exit(0 if result else 1)

if __name__ == '__main__':
    main()
